<Window x:Class="PAS.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AboutWindowTitle}"
        Height="450" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F3F3F3"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#616161"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    </Window.Resources>

    <Grid Margin="22">
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24,26,24,24">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="360">
                <Border Width="82"
                        Height="82"
                        CornerRadius="8"
                        Background="#F8F8F8"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,2,0,18"
                        ClipToBounds="False">
                    <Image Width="56"
                           Height="56"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Source>
                            <BitmapImage UriSource="pack://application:,,,/icon.ico"
                                         DecodePixelWidth="56"
                                         DecodePixelHeight="56"/>
                        </Image.Source>
                    </Image>
                </Border>

                <TextBlock Text="{Binding AboutAppTitle}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="{Binding AboutVersion}"
                           FontSize="13"
                           Foreground="{StaticResource MutedTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>

                <TextBlock Text="{Binding AboutAppDescription}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,18"
                           MaxWidth="350"/>

                <TextBlock Text="{Binding AboutDeveloper}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,7"/>

                <TextBlock HorizontalAlignment="Center"
                           Margin="0,0,0,18"
                           FontSize="12">
                    <Hyperlink Foreground="{StaticResource AccentBrush}"
                               NavigateUri="https://github.com/Almanex/Almanex-PAS_Portable-App-Sync"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{Binding AboutGithub, Mode=OneWay}"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Text="{Binding AboutLicense}"
                           FontSize="12"
                           Foreground="#8A8A8A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
