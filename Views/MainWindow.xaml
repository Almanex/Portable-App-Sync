<ui:FluentWindow x:Class="PAS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:PAS.ViewModels"
        xmlns:svc="clr-namespace:PAS.Services"
        mc:Ignorable="d"
        Title="PAS (Portable App Sync)" Height="740" Width="1140"
        MinHeight="670" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Icon="/icon.ico"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <ObjectDataProvider x:Key="L" ObjectType="{x:Type svc:LocalizationManager}"
                            MethodName="get_Instance"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="PAS (Portable App Sync)" ShowMaximize="True" ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/icon.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Panel -->
            <ui:Card Grid.Row="0" Padding="18" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="PAS"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Portable App Sync"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="1,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Language Selection -->
                        <TextBlock Text="{Binding Source={StaticResource L}, Path=LanguageLabel}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="LanguageCombo"
                                   Width="112"
                                   SelectedValuePath="Tag"
                                   VerticalAlignment="Center"
                                   SelectionChanged="LanguageCombo_SelectionChanged"
                                   Margin="0,0,16,0">
                            <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                            <ComboBoxItem Content="Русский" Tag="ru"/>
                            <ComboBoxItem Content="Deutsch" Tag="de"/>
                        </ComboBox>

                        <!-- Theme Selection -->
                        <TextBlock Text="{Binding Source={StaticResource L}, Path=ThemeLabel}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="ThemeCombo"
                                   Width="112"
                                   SelectedValuePath="Tag"
                                   VerticalAlignment="Center"
                                   SelectionChanged="ThemeCombo_SelectionChanged"
                                   Margin="0,0,16,0">
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=ThemeSystem}" Tag="system" IsSelected="True"/>
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=ThemeLight}" Tag="light"/>
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=ThemeDark}" Tag="dark"/>
                        </ComboBox>

                        <ui:Button Content="{Binding Source={StaticResource L}, Path=HelpButton}"
                                   Command="{Binding ShowHelpCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon QuestionCircle24}"
                                   Margin="0,0,10,0"/>

                        <ui:Button ToolTip="{Binding Source={StaticResource L}, Path=AboutButton}"
                                   Command="{Binding ShowAboutCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Info24}"
                                   Width="38"
                                   Padding="0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Filter Panel -->
            <ui:Card Grid.Row="1" Margin="0,0,0,14" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0"
                                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                   PlaceholderText="{Binding Source={StaticResource L}, Path=SearchPlaceholder}"
                                   Icon="{ui:SymbolIcon Search24}"
                                   ClearButtonEnabled="True"/>

                        <ui:Button Grid.Column="1"
                                   Content="{Binding Source={StaticResource L}, Path=RefreshButton}"
                                   Command="{Binding ScanCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon ArrowClockwise24}"
                                   Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0"
                                   Content="{Binding Source={StaticResource L}, Path=SelectAll}"
                                   Command="{Binding SelectAllCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Checkmark24}"
                                   Margin="0,0,8,0"/>

                        <ui:Button Grid.Column="1"
                                   Content="{Binding Source={StaticResource L}, Path=UnselectAll}"
                                   Command="{Binding UnselectAllCommand}"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Margin="0,0,14,0"/>

                        <CheckBox Grid.Column="2"
                                     Content="{Binding Source={StaticResource L}, Path=ShowSystemApps}"
                                     IsChecked="{Binding ShowAllApps}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,18,0"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding Source={StaticResource L}, Path=AppFilterLabel}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="4"
                                   Width="190"
                                   SelectedValue="{Binding SelectedAppFilter, Mode=TwoWay}"
                                   SelectedValuePath="Tag"
                                   VerticalAlignment="Center">
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=AppFilterAll}"
                                          Tag="All"
                                          IsSelected="True"/>
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=AppFilterOfflineReady}"
                                          Tag="OfflineReady"/>
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=AppFilterOnlineFallback}"
                                          Tag="OnlineFallback"/>
                            <ComboBoxItem Content="{Binding Source={StaticResource L}, Path=AppFilterExcluded}"
                                          Tag="Excluded"/>
                        </ComboBox>

                        <TextBlock Grid.Column="5"
                                   Text="{Binding SelectedCountText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="18,0,0,0"/>
                    </Grid>
                </Grid>
            </ui:Card>

            <!-- DataGrid Panel -->
            <Border Grid.Row="2"
                    Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <DataGrid ItemsSource="{Binding FilteredApplications}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                          VerticalGridLinesBrush="Transparent"
                          HeadersVisibility="All"
                          RowHeaderWidth="42"
                          RowHeight="38"
                          BorderThickness="0"
                          Background="Transparent"
                          LoadingRow="DataGrid_LoadingRow">

                    <DataGrid.RowHeaderStyle>
                        <Style TargetType="DataGridRowHeader">
                            <Setter Property="Width" Value="42"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRowHeader">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="0,0,8,0">
                                            <ContentPresenter HorizontalAlignment="Right"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                             BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                             BorderThickness="1">
                                        <TextBlock Text="{Binding Description}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="340"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Padding="8"/>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSelectedTextBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorSelectedTextBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,10"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="OK"
                                               Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                               Width="54"/>

                        <DataGridTemplateColumn Header="!" Width="42">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="!"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#D97706"
                                               HorizontalAlignment="Center"
                                               ToolTip="{Binding Source={StaticResource L}, Path=OfflineWarningTooltip}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SupportsOfflineDownload}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{Binding Source={StaticResource L}, Path=ColName}"
                                           Binding="{Binding Name}"
                                           Width="2*"
                                           IsReadOnly="True"/>

                        <DataGridTextColumn Header="{Binding Source={StaticResource L}, Path=ColPackageId}"
                                           Binding="{Binding WingetId}"
                                           Width="2*"
                                           IsReadOnly="True"/>

                        <DataGridTextColumn Header="{Binding Source={StaticResource L}, Path=ColVersion}"
                                           Binding="{Binding Version}"
                                           Width="*"
                                           IsReadOnly="True"/>

                        <DataGridTextColumn Header="{Binding Source={StaticResource L}, Path=ColStatus}"
                                           Binding="{Binding Status}"
                                           Width="*"
                                           IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Export Options Panel -->
            <ui:Card Grid.Row="3" Margin="0,14,0,0" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Source={StaticResource L}, Path=ExportGroupHeader}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <RadioButton Content="{Binding Source={StaticResource L}, Path=ExportOnlineOption}"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=OnlineScript}"
                                     Margin="0,0,0,8"/>

                        <RadioButton Content="{Binding Source={StaticResource L}, Path=ExportOfflineOption}"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=OfflinePackage}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Width="360"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ProgressText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,7"/>
                        <ProgressBar Value="{Binding ProgressValue}"
                                     IsIndeterminate="{Binding IsScanning}"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Actions Panel -->
            <ui:Card Grid.Row="4"
                     Margin="0,14,0,0"
                     Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:Button Content="{Binding ExportButtonText}"
                                   Command="{Binding ExportCommand}"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Save24}"
                                   Width="230"
                                   Height="46"
                                   FontSize="15"
                                   Padding="0,10"
                                   Margin="0,0,10,0"/>

                        <ui:Button Content="{Binding Source={StaticResource L}, Path=CancelButton}"
                                   Command="{Binding CancelExportCommand}"
                                   Appearance="Danger"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Height="46"
                                   FontSize="15"
                                   Padding="18,10"
                                   Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="16,0,16,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{Binding Source={StaticResource L}, Path=LastExportSummaryHeader}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,3,0,0"
                                   Visibility="{Binding HasLastExportSummary, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Text="{Binding LastExportSummary}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemAccentColorBrush}"
                                   HorizontalAlignment="Right"
                                   MaxHeight="18"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding LastExportSummary}"
                                   Visibility="{Binding HasLastExportSummary, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <ui:Button Grid.Column="2"
                               Content="{Binding Source={StaticResource L}, Path=OpenExportFolder}"
                               Command="{Binding OpenExportFolderCommand}"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               Padding="12,8"
                               VerticalAlignment="Center"
                               Visibility="{Binding CanOpenExportFolder, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</ui:FluentWindow>
